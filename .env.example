# ─── Banco de dados (Supabase) ───────────────────────────────────────────────
# Obter em: supabase.com → projeto → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres.<SEU_PROJECT_REF>:<SUA_SENHA>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=5"
DIRECT_URL="postgresql://postgres.<SEU_PROJECT_REF>:<SUA_SENHA>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?connect_timeout=5"
NEXT_PUBLIC_SUPABASE_URL="https://<SEU_PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<CHAVE_ANON_DO_SUPABASE>"
SUPABASE_SERVICE_ROLE_KEY="<CHAVE_SERVICE_ROLE_DO_SUPABASE>"

# ─── OpenAI (chatbot público + chat admin) ───────────────────────────────────
# Obter em: platform.openai.com → API Keys
