generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id           String    @id @default(cuid())
  nome         String
  email        String
  telefone     String?
  tipoDecl     String?
  origem       String    @default("organico")
  status       String    @default("novo")
  mensagem     String?
  emailSeqStep Int       @default(0)
  emailSeqAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([emailSeqStep])
  @@map("leads")
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  summary    String?
  content    String
  faqsJson   String   @default("[]")
  reviewJson String   @default("") @map("review_json")
  aiModel    String   @default("") @map("ai_model")
  tags       String[]
  coverImage String?
  imageAlt   String   @default("") @map("image_alt")
  imageAttribution String?  @map("image_attribution")
  published  Boolean  @default(false)
  metaTitle  String?
  metaDesc   String?
  keywords   String[]
  views      Int      @default(0)
  readTime   Int      @default(5)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([published, createdAt])
  @@map("blog_posts")
}

model Contato {
  id        String   @id @default(cuid())
  nome      String
  email     String
  telefone  String?
  assunto   String?
  mensagem  String
  lido      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contatos")
}

model EbookDownload {
  id        String   @id @default(cuid())
  nome      String
  email     String
  whatsapp  String?
  emailSeq  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("ebook_downloads")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String   @default("Admin")
  email        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model Analise {
  id         String   @id @default(cuid())
  resumo     String
  dados      String
  totalPosts Int      @default(0)
  totalLeads Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("analises")
}

model CampanhaGerada {
  id         String   @id @default(cuid())
  nome       String
  objetivo   String
  plataforma String
  dados      String
  createdAt  DateTime @default(now())

  @@map("campanhas_geradas")
}

model KnowledgeBase {
  id          String   @id @default(cuid())
  sourceUrl   String
  sourceTitle String?
  content     String   @db.Text
  category    String
  year        Int?
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  isActive    Boolean  @default(true)

  @@unique([sourceUrl, category])
  @@index([category, year, isActive])
  @@map("knowledge_base")
}

model KeywordHistory {
  id       String   @id @default(cuid())
  keyword  String
  cluster  String
  postId   String?
  usedAt   DateTime @default(now())

  @@index([usedAt])
  @@index([keyword])
  @@map("keyword_history")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  page        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  scrollDepth Int?
  timeOnPage  Int?
  element     String?
  country     String?
  region      String?
  city        String?
  device      String?
  browser     String?
  os          String?
  screenW     Int?
  screenH     Int?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([page])
  @@index([createdAt])
  @@index([sessionId])
  @@map("analytics_events")
}
